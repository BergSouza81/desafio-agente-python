# Variáveis de ambiente para o Python Agent Challenge
# Copie este arquivo para .env e preencha com suas credenciais

# Cliente LLM (OpenAI, Groq, Ollama, etc.)
OPENAI_API_KEY=sua_chave_aqui
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-8b-8192

# Knowledge Base (URL do Markdown)
KB_URL=https://raw.githubusercontent.com/igortce/python-agent-challenge/refs/heads/main/python_agent_knowledge_base.md
